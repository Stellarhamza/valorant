---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import PageHeader from "@/layouts/components/PageHeader.astro";
import { getPageStructuredData } from "@/lib/seo";
import seo from "@/config/seo.json";
import { render } from "astro:content";

// get static paths for all pages
export async function getStaticPaths() {
  const COLLECTION_FOLDER = "pages";

  const pages = await getSinglePage(COLLECTION_FOLDER);

  const paths = pages.map((page) => ({
    params: {
      regular: page.id,
    },
    props: { page },
  }));
  return paths;
}

const { page } = Astro.props;
const { title, description, meta_title, keywords, image } = page.data;
const { Content } = await render(page);

const pagePath = `/${page.id}`;
const pageSeo =
  page.id === "privacy-policy"
    ? seo.pages.privacy
    : page.id === "term-and-condition"
      ? seo.pages.terms
      : undefined;
const metaTitle = meta_title ?? pageSeo?.meta_title ?? title ?? "ValorantCheat.com";
const metaDescription =
  description ?? pageSeo?.description ?? "Information from ValorantCheat.com.";
---

<Base
  title={title}
  meta_title={metaTitle}
  description={metaDescription}
  keywords={keywords ?? pageSeo?.keywords}
  image={image || seo.default_og_image}
  ogImageAlt={metaTitle}
  canonical={pagePath}
  structuredData={getPageStructuredData(
    pagePath,
    metaTitle,
    metaDescription,
    title,
  )}
>
  <PageHeader title={title} subtitle={description!} />
  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">
          <div class="content">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
