---
import Base from "@/layouts/Base.astro";
import BlogCard from "@/layouts/components/BlogCard.astro";
import CallToAction from "@/layouts/components/CallToAction.astro";
import FeaturedPostCard from "@/layouts/components/FeaturedPostCard.astro";
import VideoShowcase from "@/layouts/components/VideoShowcase.astro";
import { getBlogVideo } from "@/config/videos";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { sortByDate } from "@/lib/utils/sortFunctions";
import { markdownify } from "@/lib/utils/textConverter";
import type { BlogIndex } from "@/types";
import seo from "@/config/seo.json";
import { getBlogIndexStructuredData } from "@/lib/seo";

const blogIndex = await getListPage("blogIndex", "-index");
const pageData: BlogIndex = blogIndex.data;

const allPosts = sortByDate(await getSinglePage("blog"));

const featuredId = pageData.page_header?.featured_post;
const featuredPost =
  (featuredId ? allPosts.find((p) => p.id === featuredId) : undefined) ??
  allPosts[0];

const blogMetaTitle =
  pageData.meta_title ?? seo.pages.blog.meta_title ?? pageData.title;
const blogDescription =
  pageData.description ?? seo.pages.blog.description;
const blogKeywords =
  pageData.keywords ?? seo.pages.blog.keywords ?? seo.default_keywords;

const blogIndexJsonLd = getBlogIndexStructuredData(
  blogMetaTitle,
  blogDescription,
  allPosts.map((post) => ({
    id: post.id,
    title: post.data.title,
  })),
);
---

<Base
  {...pageData}
  meta_title={blogMetaTitle}
  description={blogDescription}
  image={pageData.image ?? seo.default_og_image}
  ogImageAlt={blogMetaTitle}
  canonical="/blog"
  keywords={blogKeywords}
  structuredData={blogIndexJsonLd}
>
  <section class="section-ph pb-10 relative">
    <div class="container relative">
      <div class="absolute top-0 left-0 w-full pointer-events-none">
        <div class="h-100 w-full overflow-hidden -translate-y-10">
          <canvas class="heroSporeCanvas w-full opacity-70"></canvas>
        </div>
      </div>
      <div class="lg:max-w-4xl mx-auto text-center relative z-10">
        <h1
          class="hasHighlight mb-4"
          set:html={markdownify(pageData.page_header?.title ?? pageData.title)}
        />
        <p class="text-text text-lg max-w-2xl mx-auto">
          {pageData.description}
        </p>
      </div>
    </div>
    <div
      class="absolute left-1/2 top-0 -translate-y-1/2 -translate-x-1/2 size-160 xl:size-300 -z-20 blur-2xl pointer-events-none"
      style="background: radial-gradient(circle, var(--color-primary) 0%, color-mix(in srgb, var(--color-primary) 78%, transparent) 20%, transparent 70%);"
    >
    </div>
  </section>

  {
    allPosts.length === 0 ? (
      <section class="section pt-0">
        <div class="container text-center">
          <p class="text-text text-lg">No guides published yet. Check back soon.</p>
        </div>
      </section>
    ) : (
      <>
        {
          (pageData.featured_post?.enable ?? true) && featuredPost && (
            <section class="section pt-0">
              <div class="container">
                <p class="text-sm uppercase tracking-wider text-primary mb-4 text-center">
                  Featured guide
                </p>
                <div class="grid gap-4 lg:grid-cols-[1fr_1.03fr]">
                  <VideoShowcase
                    src={getBlogVideo(featuredPost.id, 0)}
                    gsap={false}
                    class="rounded-2xl border border-white/10 max-w-none min-h-64"
                  />
                  <FeaturedPostCard
                    tag={featuredPost.data.tag ?? "Guide"}
                    title={featuredPost.data.title}
                    description={featuredPost.data.description ?? ""}
                    authorImage={
                      featuredPost.data.author_image ??
                      "/images/blog/author-1.png"
                    }
                    authorName={featuredPost.data.author}
                    date={dateFormat(featuredPost.data.date ?? new Date())}
                    readTime={featuredPost.data.read_time ?? "5 min read"}
                    href={`/blog/${featuredPost.id}`}
                  />
                </div>
                <hr class="mt-16 h-px border-0 bg-linear-to-r from-transparent via-white/15 to-transparent" />
              </div>
            </section>
          )
        }

        {
          (pageData.latest_posts?.enable ?? true) && (
            <section class="section pt-10 lg:pt-14">
              <div class="container relative isolate">
                <div class="mb-12 text-center">
                  <h2 class="text-h3-sm md:text-h2">
                    {pageData.latest_posts?.title ?? "All guides"} ({allPosts.length})
                  </h2>
                </div>

                <nav
                  class="sr-only"
                  aria-label="All Valorant cheat guides (sitemap for crawlers)"
                >
                  <ul>
                    {allPosts.map((post) => (
                      <li>
                        <a href={`/blog/${post.id}`}>{post.data.title}</a>
                      </li>
                    ))}
                  </ul>
                </nav>

                <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                  {allPosts.map((post, index) => (
                    <BlogCard
                      image={post.data.image ?? "/images/blog/post-1.png"}
                      imageAlt={post.data.title}
                      title={post.data.title}
                      description={post.data.description ?? ""}
                      authorImage={
                        post.data.author_image ?? "/images/blog/author-1.png"
                      }
                      authorName={post.data.author}
                      date={dateFormat(post.data.date ?? new Date())}
                      href={`/blog/${post.id}`}
                      video={getBlogVideo(post.id, index)}
                    />
                  ))}
                </div>

                <div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 size-310.5 -translate-x-1/2 -translate-y-1/3 rounded-full bg-radial from-primary/16 from-0% to-transparent to-70% blur-2xl" />
              </div>
            </section>
          )
        }
      </>
    )
  }

  <CallToAction />
</Base>
