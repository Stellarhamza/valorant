---
import config from "@/config/config.json";
import seoConfig from "@/config/seo.json";
import theme from "@/config/theme.json";
import { resolveCanonicalUrl } from "@/lib/seo";
import { resolveOgImageMeta, truncateMetaDescription } from "@/lib/meta";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import { Font } from "astro:assets";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";

const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  keywords?: string;
  noindex?: boolean;
  canonical?: string;
  structuredData?: Record<string, unknown>;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  ogImageAlt?: string;
  articleTags?: string[];
  articleAuthor?: string;
}

const {
  title,
  meta_title,
  description,
  image,
  keywords,
  noindex,
  canonical,
  structuredData,
  ogType = "website",
  publishedTime,
  modifiedTime,
  ogImageAlt,
  articleTags = [],
  articleAuthor,
} = Astro.props;

const pageTitle = plainify(
  meta_title ? meta_title : title ? title : config.site.title,
);
const pageDescription = truncateMetaDescription(
  plainify(description ? description : config.metadata.meta_description),
);
const canonicalUrl = resolveCanonicalUrl(Astro.url.pathname, canonical);
const ogImage = resolveOgImageMeta(image, ogImageAlt ?? pageTitle);
const pageKeywords =
  keywords ?? seoConfig.default_keywords ?? undefined;
const siteHost = new URL(seoConfig.site_url).hostname;
const articleModified = modifiedTime ?? publishedTime;
---

<!doctype html>
<html lang="en">
  <head>
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }

    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />

    <link rel="icon" href={config.site.favicon} type="image/png" sizes="any" />
    <link rel="shortcut icon" href={config.site.favicon} />
    <link rel="apple-touch-icon" href={config.site.favicon} />
    <link rel="home" href={resolveCanonicalUrl("/")} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link
      rel="sitemap"
      type="application/xml"
      title="Sitemap"
      href="/sitemap-index.xml"
    />

    <meta name="msapplication-TileColor" content="#86198F" />
    <meta name="theme-color" content="#86198F" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />

    <link
      rel="preconnect"
      href="https://bryjchknhsrmjdunnfer.supabase.co"
      crossorigin
    />
    <link
      rel="preconnect"
      href="https://ooszazcwzmwhitdxwtom.supabase.co"
      crossorigin
    />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return (
          <Font
            cssVariable={cssVar}
            preload={key === "primary"}
            fetchpriority={key === "primary" ? "high" : "low"}
          />
        );
      })
    }

    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />

    {
      noindex ? (
        <meta name="robots" content="noindex,nofollow" />
      ) : (
        <>
          <meta
            name="robots"
            content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
          />
          <meta
            name="googlebot"
            content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
          />
          <meta
            name="bingbot"
            content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
          />
        </>
      )
    }

    <meta name="description" content={pageDescription} />
    {pageKeywords && <meta name="keywords" content={pageKeywords} />}
    <meta name="author" content={config.metadata.meta_author} />
    <meta name="publisher" content={seoConfig.brand_domain} />
    <meta name="application-name" content={seoConfig.brand_domain} />

    <!-- Open Graph (Facebook, Discord, LinkedIn, iMessage) -->
    <meta property="og:site_name" content={seoConfig.brand_domain} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={seoConfig.locale ?? "en_US"} />
    <meta property="og:image" content={ogImage.url} />
    <meta property="og:image:secure_url" content={ogImage.url} />
    <meta property="og:image:type" content={ogImage.type} />
    <meta property="og:image:width" content={String(ogImage.width)} />
    <meta property="og:image:height" content={String(ogImage.height)} />
    <meta property="og:image:alt" content={ogImage.alt} />

    {
      ogType === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === "article" && articleModified && (
        <meta property="article:modified_time" content={articleModified} />
      )
    }
    {
      ogType === "article" && (
        <>
          <meta property="article:section" content="Valorant Cheats" />
          <meta
            property="article:author"
            content={articleAuthor ?? config.metadata.meta_author}
          />
          <meta property="og:updated_time" content={articleModified ?? publishedTime} />
        </>
      )
    }
    {
      ogType === "article" &&
        articleTags.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <!-- Twitter / X Card -->
    <meta
      name="twitter:card"
      content={seoConfig.twitter_card ?? "summary_large_image"}
    />
    {
      seoConfig.twitter_handle && (
        <>
          <meta name="twitter:site" content={seoConfig.twitter_handle} />
          <meta name="twitter:creator" content={seoConfig.twitter_handle} />
        </>
      )
    }
    <meta name="twitter:domain" content={siteHost} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage.url} />
    <meta name="twitter:image:alt" content={ogImage.alt} />

    {
      structuredData && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
  </head>
  <body>
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }

    <Header />
    <main id="main-content" class="overflow-x-hidden md:overflow-x-auto">
      <slot />
    </main>
    <Footer />

    <script is:inline defer src="/scripts/main.js"></script>
    <script>
      const bootAnimations = () => import("@/scripts/animations");
      if ("requestIdleCallback" in window) {
        requestIdleCallback(() => bootAnimations(), { timeout: 2500 });
      } else {
        window.addEventListener("load", () => bootAnimations(), { once: true });
      }
    </script>
  </body>
</html>
