---
import config from "@/config/config.json";
import seoConfig from "@/config/seo.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import { resolveCanonicalUrl, resolveOgImage, SITE_NAME } from "@/lib/seo";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import { Font } from "astro:assets";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";

const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  keywords?: string;
  noindex?: boolean;
  canonical?: string;
  structuredData?: Record<string, unknown>;
  ogType?: "website" | "article";
}

const {
  title,
  meta_title,
  description,
  image,
  keywords,
  noindex,
  canonical,
  structuredData,
  ogType = "website",
} = Astro.props;

const pageTitle = plainify(
  meta_title ? meta_title : title ? title : config.site.title,
);
const pageDescription = plainify(
  description ? description : config.metadata.meta_description,
);
const canonicalUrl = resolveCanonicalUrl(Astro.url.pathname, canonical);
const ogImageUrl = resolveOgImage(image);
const pageKeywords =
  keywords ?? seoConfig.default_keywords ?? undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- google tag manager -->
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }
    <link rel="icon" href={config.site.favicon} sizes="any" />
    <link rel="shortcut icon" href={config.site.favicon} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <meta name="msapplication-TileColor" content="#86198F" />
    <meta name="theme-color" content="#86198F" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <link rel="preconnect" href="https://bryjchknhsrmjdunnfer.supabase.co" crossorigin />
    <link rel="preconnect" href="https://ooszazcwzmwhitdxwtom.supabase.co" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return (
          <Font
            cssVariable={cssVar}
            preload={key === "primary"}
            fetchpriority={key === "primary" ? "high" : "low"}
          />
        );
      })
    }

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <title>{pageTitle}</title>

    {noindex ? (
      <meta name="robots" content="noindex,nofollow" />
    ) : (
      <meta name="robots" content="index,follow,max-image-preview:large" />
    )}
    <meta name="description" content={pageDescription} />
    {pageKeywords && <meta name="keywords" content={pageKeywords} />}

    <meta name="author" content={config.metadata.meta_author} />
    <meta name="application-name" content={seoConfig.brand_domain} />
    <meta property="og:site_name" content={seoConfig.brand_domain} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
  {
    seoConfig.twitter_handle && (
      <meta name="twitter:site" content={seoConfig.twitter_handle} />
    )
  }
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      structuredData && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }

  </head>
  <body>
    {/* google tag manager noscript */}
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }

    {/* <TwSizeIndicator /> */}
    <Header />
    <main id="main-content" class="overflow-x-hidden md:overflow-x-auto">
      <slot />
    </main>
    <Footer />

    <script is:inline defer src="/scripts/main.js"></script>
    <script>
      const bootAnimations = () => import("@/scripts/animations");
      if ("requestIdleCallback" in window) {
        requestIdleCallback(() => bootAnimations(), { timeout: 2500 });
      } else {
        window.addEventListener("load", () => bootAnimations(), { once: true });
      }
    </script>
  </body>
</html>
